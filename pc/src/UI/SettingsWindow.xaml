<Window x:Class="BtInput.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BT Input 设置"
        Width="460"
        Height="300"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Text="设置"/>

        <StackPanel Grid.Row="1"
                    Margin="0,16,0,0">
            <TextBlock FontSize="13"
                       FontWeight="SemiBold"
                       Text="快捷键"/>
            <TextBox x:Name="HotkeyTextBox"
                     Margin="0,6,0,0"
                     IsReadOnly="True"
                     Height="32"
                     VerticalContentAlignment="Center"
                     PreviewKeyDown="HotkeyTextBox_OnPreviewKeyDown"/>
            <TextBlock Margin="0,6,0,0"
                       FontSize="12"
                       Foreground="#66000000"
                       Text="点击输入框后按下组合键（如 Ctrl+Shift+B）"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Margin="0,16,0,0">
            <CheckBox x:Name="AutoStartCheckBox"
                      Content="开机自启动"/>
            <CheckBox x:Name="RememberDeviceCheckBox"
                      Margin="0,8,0,0"
                      Content="记住上次连接的设备"/>
            <CheckBox x:Name="DebugModeCheckBox"
                      Margin="0,8,0,0"
                      Content="启用 Debug 监控日志"/>
        </StackPanel>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="88"
                    Height="32"
                    Margin="0,0,8,0"
                    Content="取消"
                    Click="CancelButton_OnClick"/>
            <Button Width="88"
                    Height="32"
                    Content="保存"
                    Click="SaveButton_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
